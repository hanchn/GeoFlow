            <div class="side-doctor-info">
              <strong>李雪梅</strong>
              <span>副主任医师 · 儿童皮肤科</span>
            </div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-lighter)" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </a>
          <a href="#" class="side-doctor-item">
            <div class="side-doctor-avatar" style="background: #1864ff;">王</div>
