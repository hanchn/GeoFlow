<footer class="site-footer" id="contact">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="brand brand-footer">
        <span class="brand-mark">医</span>
        <span>
          <strong>{{ site.name }}</strong>
          <small>专注皮肤专病诊疗</small>
        </span>
      </div>
      <p>专业皮肤专病诊疗平台，汇聚白癜风及银屑病专病能力，为患者提供专业、权威、可信赖的医疗服务。</p>
      <ul class="footer-meta">
        <li>{{ site.phone }}</li>
        <li>北京市朝阳区健康路专科中心A座</li>
        <li>周一至周日 08:00-17:30</li>
        <li>contact@hospital.com</li>
      </ul>
    </div>

    {% for group in footerGroups %}
    <div class="footer-column">
      <h3>{{ group.title }}</h3>
      <ul>
        {% for link in group.links %}
        <li><a href="{{ link.href }}">{{ link.label }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>

  <div class="container footer-bottom">
    <span>© 2026 {{ site.name }} · 京ICP备202600001号</span>
    <span>隐私政策 · 使用条款 · 免责声明</span>
  </div>
</footer>
