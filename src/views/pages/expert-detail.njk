            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 4px;">上</div>
            <div style="background: var(--surface-soft); color: var(--text-lighter); padding: 4px 0; border-radius: 4px;">上</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 4px;">上</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 4px;">上</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 4px;">上</div>
            <div style="background: var(--surface-soft); color: var(--text-lighter); padding: 4px 0; border-radius: 4px;">上</div>
            
            <!-- 下午 -->
            <div style="background: var(--surface-soft); color: var(--text-lighter); padding: 4px 0; border-radius: 4px;">下</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 4px;">下</div>
            <div style="background: var(--surface-soft); color: var(--text-lighter); padding: 4px 0; border-radius: 4px;">下</div>
            <div style="background: var(--surface-soft); color: var(--text-lighter); padding: 4px 0; border-radius: 4px;">下</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 4px;">下</div>
            <div style="background: var(--surface-soft); color: var(--text-lighter); padding: 4px 0; border-radius: 4px;">下</div>
            <div style="background: var(--surface-soft); color: var(--text-lighter); padding: 4px 0; border-radius: 4px;">下</div>
          </div>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: #eff6ff; border-radius: 8px; margin-bottom: 24px;">
          <span style="font-size: 0.875rem; color: var(--text-soft);">挂号费</span>
          <strong style="font-size: 1.25rem; color: #1864ff;">¥{{ doctor.fee | default(300) }}</strong>
        </div>

        <button style="width: 100%; padding: 12px 0; background: #1864ff; color: #fff; border: none; border-radius: 8px; font-size: 1rem; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 12px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          立即预约
        </button>
        
        <button style="width: 100%; padding: 12px 0; background: #ffffff; color: var(--text); border: 1px solid var(--line); border-radius: 8px; font-size: 1rem; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          电话咨询
        </button>
        
        <p style="text-align: center; margin: 16px 0 0 0; font-size: 0.75rem; color: var(--text-lighter);">已有 <strong>{{ doctor.cases }}</strong> 位患者选择了{{ doctor.name }}医生</p>
      </div>

      <!-- 学术职务 -->
      <div class="card" style="padding: 24px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h3 style="margin: 0 0 16px 0; font-size: 1rem; color: var(--text);">学术职务</h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; font-size: 0.875rem; color: var(--text-soft);">
