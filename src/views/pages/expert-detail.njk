{% extends "layouts/base.njk" %}

{% block content %}
<!-- 面包屑与顶部操作栏 -->
<div class="page-header" style="background: #ffffff; border-bottom: 1px solid var(--line); padding: 16px 0; position: sticky; top: 72px; z-index: 10;">
  <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
    <div class="breadcrumb" style="display: flex; align-items: center; gap: 8px; color: var(--text-soft); font-size: 0.875rem;">
      <a href="/" style="color: var(--text-soft); text-decoration: none;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: text-bottom; margin-right: 4px;"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg> {{ site.name }}</a>
      <span style="color: #cbd5e1;">/</span>
      <span style="color: var(--text); font-weight: 500;">专家详情</span>
    </div>
    <a href="{{ site.appointmentPath }}" class="button primary" style="border-radius: 8px; padding: 8px 16px; height: 36px; font-size: 0.875rem; background: #1864ff; color: #fff; border: none; display: inline-flex; align-items: center; gap: 6px; cursor: pointer;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      预约挂号
    </a>
  </div>
</div>

<div style="padding: 24px 0 64px;">
  <div class="container layout-sidebar">
    
    <!-- 左侧主列 -->
    <div class="main-content" style="display: flex; flex-direction: column; gap: 24px;">
      
      <!-- 医生名片 -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <div style="display: flex; gap: 24px;">
          <div class="avatar" style="width: 100px; height: 100px; border-radius: 16px; background: #1864ff; color: #ffffff; font-size: 2.5rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            {{ expert.name | first }}
          </div>
          <div style="flex: 1;">
            <div style="display: flex; align-items: baseline; gap: 12px; margin-bottom: 12px;">
              <h1 style="font-size: 1.75rem; font-weight: 700; margin: 0; color: var(--text);">{{ expert.name }}</h1>
              <span style="color: var(--text-soft); font-size: 0.875rem; background: var(--surface-soft); padding: 4px 8px; border-radius: 4px;">{{ expert.title }}</span>
            </div>
            
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px; font-size: 0.875rem;">
              <span style="color: #1864ff; background: #eff6ff; padding: 4px 8px; border-radius: 4px; font-weight: 500;">{{ expert.department }}</span>
              <span style="color: var(--text-soft);">从业{{ expert.experience }}年 · 诊治{{ expert.cases }}+例</span>
            </div>

            <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px;">
              {% for tag in expert.tags %}
              <span style="color: #1864ff; border: 1px solid #bfdbfe; padding: 2px 10px; border-radius: 12px; font-size: 0.75rem;">{{ tag }}</span>
              {% endfor %}
            </div>

            <p style="color: var(--text); line-height: 1.6; font-size: 0.9375rem; margin: 0;">{{ expert.description }}</p>
          </div>
        </div>

        <!-- 数据指标块 -->
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 32px; border-top: 1px solid var(--line); padding-top: 32px;">
          <div style="background: #f8fafc; padding: 16px; border-radius: 12px; text-align: center;">
            <strong style="display: block; color: #1864ff; font-size: 1.25rem; font-weight: 700; margin-bottom: 4px;">{{ expert.experience }}年</strong>
            <span style="color: var(--text-soft); font-size: 0.75rem;">从业年限</span>
          </div>
          <div style="background: #f8fafc; padding: 16px; border-radius: 12px; text-align: center;">
            <strong style="display: block; color: #1864ff; font-size: 1.25rem; font-weight: 700; margin-bottom: 4px;">{{ expert.cases }}+</strong>
            <span style="color: var(--text-soft); font-size: 0.75rem;">诊治病例</span>
          </div>
          <div style="background: #f8fafc; padding: 16px; border-radius: 12px; text-align: center;">
            <strong style="display: block; color: #1864ff; font-size: 1.25rem; font-weight: 700; margin-bottom: 4px;">{{ expert.score }}</strong>
            <span style="color: var(--text-soft); font-size: 0.75rem;">患者评分</span>
          </div>
          <div style="background: #f8fafc; padding: 16px; border-radius: 12px; text-align: center;">
            <strong style="display: block; color: #1864ff; font-size: 1.25rem; font-weight: 700; margin-bottom: 4px;">¥{{ expert.fee }}</strong>
            <span style="color: var(--text-soft); font-size: 0.75rem;">挂号费</span>
          </div>
        </div>
      </div>

      <!-- 擅长领域 -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 24px; margin-top: 0; display: flex; align-items: center; gap: 8px; color: var(--text);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1864ff" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          擅长领域
        </h2>
        <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 16px;">
          {% for spec in expert.specialties %}
          <li style="display: flex; align-items: flex-start; gap: 12px; color: var(--text); font-size: 0.9375rem; line-height: 1.5;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" style="flex-shrink: 0; margin-top: 2px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            {{ spec }}
          </li>
          {% endfor %}
        </ul>
      </div>

      <!-- 教育背景 (模拟数据) -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 24px; margin-top: 0; display: flex; align-items: center; gap: 8px; color: var(--text);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1864ff" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
          教育背景
        </h2>
        <div style="display: grid; gap: 20px;">
          <div style="display: flex; gap: 16px;">
            <span style="color: var(--text-soft); background: var(--surface-soft); padding: 4px 8px; border-radius: 4px; font-size: 0.8125rem; height: fit-content; flex-shrink: 0;">1992-1997</span>
            <div>
              <strong style="display: block; color: var(--text); font-size: 0.9375rem; margin-bottom: 4px;">北京协和医学院</strong>
              <span style="color: var(--text-soft); font-size: 0.875rem;">临床医学学士</span>
            </div>
          </div>
        </div>
      </div>
      
    </div>

    <!-- 右侧边栏 -->
    <aside class="sidebar" style="display: flex; flex-direction: column; gap: 24px;">
      
      <!-- 预约卡片 -->
      <div class="card" style="padding: 24px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h3 style="font-size: 1.125rem; font-weight: 700; margin: 0 0 8px 0; color: var(--text);">预约 {{ expert.name }} 医生</h3>
        <p style="color: var(--text-soft); font-size: 0.8125rem; margin: 0 0 24px 0;">最近可约：<span style="color: #10b981; font-weight: 600;">明日 09:00</span></p>
        
        <!-- 排班表 -->
        <div style="margin-bottom: 24px;">
          <p style="font-size: 0.8125rem; color: var(--text-soft); margin: 0 0 12px 0;">本周出诊安排</p>
          <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; text-align: center; font-size: 0.75rem;">
            <div style="color: var(--text-soft); margin-bottom: 4px;">一</div><div>二</div><div>三</div><div>四</div><div>五</div><div>六</div><div>日</div>
            
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 2px;">上</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 2px;">上</div>
            <div style="background: #f1f5f9; color: #cbd5e1; padding: 4px 0; border-radius: 2px;">上</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 2px;">上</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 2px;">上</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 2px;">上</div>
            <div style="background: #f1f5f9; color: #cbd5e1; padding: 4px 0; border-radius: 2px;">上</div>
            
            <div style="background: #f1f5f9; color: #cbd5e1; padding: 4px 0; border-radius: 2px;">下</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 2px;">下</div>
            <div style="background: #f1f5f9; color: #cbd5e1; padding: 4px 0; border-radius: 2px;">下</div>
            <div style="background: #f1f5f9; color: #cbd5e1; padding: 4px 0; border-radius: 2px;">下</div>
            <div style="background: #1864ff; color: #fff; padding: 4px 0; border-radius: 2px;">下</div>
            <div style="background: #f1f5f9; color: #cbd5e1; padding: 4px 0; border-radius: 2px;">下</div>
            <div style="background: #f1f5f9; color: #cbd5e1; padding: 4px 0; border-radius: 2px;">下</div>
          </div>
        </div>

        <!-- 挂号费 -->
        <div style="background: #eff6ff; padding: 16px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
          <span style="color: var(--text-soft); font-size: 0.875rem;">挂号费</span>
          <strong style="color: #1864ff; font-size: 1.25rem;">¥{{ expert.fee }}</strong>
        </div>

        <!-- 操作按钮 -->
        <div style="display: grid; gap: 12px;">
          <a href="{{ site.appointmentPath }}" style="display: flex; justify-content: center; align-items: center; height: 44px; border-radius: 8px; background: #1864ff; color: #fff; font-size: 0.9375rem; font-weight: 500; text-decoration: none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            立即预约
          </a>
          <a href="tel:{{ site.phone }}" style="display: flex; justify-content: center; align-items: center; height: 44px; border-radius: 8px; background: #f8fafc; color: var(--text); font-size: 0.9375rem; font-weight: 500; text-decoration: none; border: 1px solid var(--line);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            电话咨询
          </a>
        </div>
        
        <p style="text-align: center; font-size: 0.75rem; color: var(--text-soft); margin: 16px 0 0 0;">
          已有 <strong style="color: var(--text);">12,000</strong> 位患者选择了{{ expert.name }}医生
        </p>
      </div>

      <!-- 学术职务 (模拟) -->
      <div class="card" style="padding: 24px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h3 style="font-size: 1rem; font-weight: 700; margin: 0 0 16px 0; color: var(--text);">学术职务</h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 12px;">
          <li style="display: flex; align-items: flex-start; gap: 8px; color: var(--text-soft); font-size: 0.8125rem; line-height: 1.5;">
            <span style="color: #1864ff; font-size: 1rem; line-height: 1;">•</span> 中国医师协会皮肤科分会委员
          </li>
          <li style="display: flex; align-items: flex-start; gap: 8px; color: var(--text-soft); font-size: 0.8125rem; line-height: 1.5;">
            <span style="color: #1864ff; font-size: 1rem; line-height: 1;">•</span> 北京医学会皮肤科学分会常委
          </li>
        </ul>
      </div>

    </aside>
  </div>
</div>
{% endblock %}
