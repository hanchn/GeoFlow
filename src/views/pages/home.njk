{% extends "layouts/base.njk" %}

{% block content %}
<section class="hero">
  <p class="eyebrow">GEO C-end Boilerplate</p>
  <h1>{{ heroTitle }}</h1>
  <p class="subtitle">{{ heroSubtitle }}</p>

  <div class="panel">
    <h2>当前环境</h2>
    <p>{{ currentEnv }}</p>
  </div>

  <div class="panel">
    <h2>当前站点</h2>
    <p>站点编码：{{ currentSite }}</p>
    <p>站点域名：{{ siteHost }}</p>
  </div>

  <div class="panel">
    <h2>支持环境</h2>
    <ul class="feature-list">
      {% for envItem in environmentList %}
      <li>{{ envItem }}</li>
      {% endfor %}
    </ul>
  </div>

  <div class="panel">
    <h2>基础能力</h2>
    <ul class="feature-list">
      {% for item in features %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </div>
</section>
{% endblock %}
