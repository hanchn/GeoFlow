{
  "name": "geoflow",
  "version": "0.1.0",
  "private": true,
  "description": "GEO consumer-facing web project based on Fastify and Nunjucks.",
  "main": "server.js",
  "scripts": {
    "dev": "APP_ENV=development APP_LOGGER=false nodemon -e js,njk,css,json server.js",
    "start": "APP_ENV=testing APP_LOGGER=false nodemon -e js,njk,css,json server.js",
    "restart": "APP_ENV=development APP_LOGGER=false nodemon -e js,njk,css,json server.js",
    "start:dev": "APP_ENV=development node --watch server.js",
    "start:test": "APP_ENV=testing node server.js",
    "start:staging": "APP_ENV=staging node server.js",
    "start:prod": "APP_ENV=production node server.js",
    "check": "node scripts/self-check.js",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^8.0.4",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/view": "^10.0.1",
    "fastify": "^5.0.0",
    "mysql2": "^3.11.3",
    "nunjucks": "^3.2.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.14"
  },
  "lint-staged": {
    "*.js": [
      "node scripts/check-staged-js.js"
    ]
  }
}
