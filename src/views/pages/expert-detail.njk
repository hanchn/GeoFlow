      <div class="card" style="padding: 24px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05); position: sticky; top: 100px;">
        <h3 style="margin: 0 0 4px 0; font-size: 1rem; color: var(--text);">预约 {{ doctor.name }} 医生</h3>
        <p style="margin: 0 0 20px 0; font-size: 0.8125rem; color: var(--text-soft);">最近可约：<strong style="color: #10b981;">明日 09:00</strong></p>
        
