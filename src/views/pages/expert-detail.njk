{% extends "layouts/base.njk" %}

{% block content %}
<!-- 面包屑与顶部操作栏 -->
<div class="page-header" style="background: #ffffff; border-bottom: 1px solid var(--line); padding: 16px 0; position: sticky; top: 72px; z-index: 10;">
  <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
    <div class="breadcrumb" style="display: flex; align-items: center; gap: 8px; color: var(--text-soft); font-size: 0.875rem;">
      <a href="/" style="color: var(--text-soft); text-decoration: none;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: text-bottom; margin-right: 4px;"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg> {{ site.name }}</a>
      <span style="color: #cbd5e1;">/</span>
      <span style="color: var(--text); font-weight: 500;">专家详情</span>
    </div>
    <a href="{{ site.appointmentPath }}" class="button primary" style="border-radius: 8px; padding: 8px 16px; height: 36px; font-size: 0.875rem; background: #1864ff; color: #fff; border: none; display: inline-flex; align-items: center; gap: 6px; cursor: pointer;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      预约挂号
    </a>
  </div>
</div>

<div style="padding: 24px 0 64px;">
  <div class="container detail-layout">
    
    <!-- 左侧主列 -->
    <div class="page-stack" style="display: flex; flex-direction: column; gap: 24px;">
      
      <!-- 医生名片 -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <div style="display: flex; gap: 24px;">
          <div class="avatar" style="width: 100px; height: 100px; border-radius: 16px; background: #1864ff; color: #ffffff; font-size: 2.5rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            {{ doctor.name | first }}
          </div>
          <div style="flex: 1;">
            <div style="display: flex; align-items: baseline; gap: 12px; margin-bottom: 12px;">
              <h1 style="font-size: 1.75rem; font-weight: 700; margin: 0; color: var(--text);">{{ doctor.name }}</h1>
              <span style="color: var(--text-soft); font-size: 0.875rem; background: var(--surface-soft); padding: 4px 8px; border-radius: 4px;">{{ doctor.title }}</span>
            </div>
            
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px; font-size: 0.875rem;">
              <span style="color: #1864ff; background: #eff6ff; padding: 4px 8px; border-radius: 4px; font-weight: 500;">{{ doctor.department }}</span>
              <span style="color: var(--text-soft);">从业{{ doctor.experience }}年 · 诊治{{ doctor.cases }}+例</span>
            </div>

            <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px;">
              {% for tag in doctor.tags %}
              <span style="color: #1864ff; border: 1px solid #bfdbfe; padding: 2px 10px; border-radius: 12px; font-size: 0.75rem;">{{ tag }}</span>
              {% endfor %}
            </div>

            <p style="color: var(--text); line-height: 1.6; font-size: 0.9375rem; margin: 0;">{{ doctor.description }}</p>
          </div>
        </div>

        <!-- 数据指标块 -->
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 32px; border-top: 1px solid var(--line); padding-top: 32px;">
          <div style="background: #f8fafc; padding: 16px; border-radius: 12px; text-align: center;">
            <strong style="display: block; color: #1864ff; font-size: 1.25rem; font-weight: 700; margin-bottom: 4px;">{{ doctor.experience }}年</strong>
            <span style="color: var(--text-soft); font-size: 0.75rem;">从业年限</span>
          </div>
          <div style="background: #f8fafc; padding: 16px; border-radius: 12px; text-align: center;">
            <strong style="display: block; color: #1864ff; font-size: 1.25rem; font-weight: 700; margin-bottom: 4px;">{{ doctor.cases }}+</strong>
            <span style="color: var(--text-soft); font-size: 0.75rem;">诊治病例</span>
          </div>
          <div style="background: #f8fafc; padding: 16px; border-radius: 12px; text-align: center;">
            <strong style="display: block; color: #1864ff; font-size: 1.25rem; font-weight: 700; margin-bottom: 4px;">{{ doctor.score }}</strong>
            <span style="color: var(--text-soft); font-size: 0.75rem;">患者评分</span>
          </div>
          <div style="background: #f8fafc; padding: 16px; border-radius: 12px; text-align: center;">
            <strong style="display: block; color: #1864ff; font-size: 1.25rem; font-weight: 700; margin-bottom: 4px;">¥{{ doctor.fee | default(300) }}</strong>
            <span style="color: var(--text-soft); font-size: 0.75rem;">挂号费</span>
          </div>
        </div>
      </div>

      <!-- 擅长领域 -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 24px; margin-top: 0; display: flex; align-items: center; gap: 8px; color: var(--text);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1864ff" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          擅长领域
        </h2>
        <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 16px;">
          {% for spec in doctor.specialties %}
          <li style="display: flex; align-items: flex-start; gap: 12px; color: var(--text); font-size: 0.9375rem; line-height: 1.5;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" style="flex-shrink: 0; margin-top: 2px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            {{ spec }}
          </li>
          {% endfor %}
        </ul>
      </div>

      <!-- 教育背景 (模拟数据) -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h2 class="detail-card-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1864ff" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
          教育背景
        </h2>
        <div class="timeline-list">
          <div class="timeline-item">
            <div class="timeline-time">1992-1997</div>
            <div class="timeline-content">
              <strong>北京协和医学院</strong>
              <span>临床医学学士</span>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-time">1997-2000</div>
            <div class="timeline-content">
              <strong>北京协和医学院</strong>
              <span>皮肤科硕士</span>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-time">2000-2003</div>
            <div class="timeline-content">
              <strong>北京协和医学院</strong>
              <span>皮肤科博士</span>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-time">2005-2006</div>
            <div class="timeline-content">
              <strong>美国哈佛医学院</strong>
              <span>访问学者 (皮肤免疫方向)</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 从业经历 (模拟数据) -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h2 class="detail-card-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1864ff" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          从业经历
        </h2>
        <div class="timeline-list">
          <div class="timeline-item">
            <div class="timeline-time" style="background: #1864ff; color: #fff;">2015-至今</div>
            <div class="timeline-content">
              <strong>北京白癜风皮肤病专科医院</strong>
              <span>白癜风科主任 · 主任医师</span>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-time">2008-2015</div>
            <div class="timeline-content">
              <strong>北京协和医院</strong>
              <span>皮肤科副主任医师</span>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-time">2003-2008</div>
            <div class="timeline-content">
              <strong>北京协和医院</strong>
              <span>皮肤科主治医师</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 学术成就 (模拟数据) -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h2 class="detail-card-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          学术成就
        </h2>
        <ul class="icon-list">
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
            国家自然科学基金项目主持人 (3项)
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
            北京市科学技术奖三等奖
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
            中国医师协会皮肤科优秀医师奖
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
            发表SCI论文22篇，累计影响因子>85
          </li>
        </ul>
      </div>

      <!-- 代表性论文 (模拟数据) -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <h2 class="detail-card-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1864ff" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          代表性论文
        </h2>
        <div class="paper-list">
          <div class="paper-item">
            <strong>NB-UVB联合他克莫司软膏治疗节段型白癜风的临床研究</strong>
            <span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
              中华皮肤科杂志 · 2024
            </span>
          </div>
          <div class="paper-item">
            <strong>Efficacy of 308-nm excimer laser in treating vitiligo: A meta-analysis</strong>
            <span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
              Journal of Dermatology · 2023
            </span>
          </div>
          <div class="paper-item">
            <strong>白癜风患者生活质量评估及影响因素分析</strong>
            <span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
              中国皮肤性病学杂志 · 2022
            </span>
          </div>
        </div>
      </div>

      <!-- 患者评价 (模拟数据) -->
      <div class="card" style="padding: 32px; border-radius: 16px; background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
          <h2 class="detail-card-title" style="margin-bottom: 0;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1864ff" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            患者评价
          </h2>
          <div style="display: flex; align-items: center; gap: 8px;">
            <div style="color: #f59e0b; display: flex; gap: 2px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
            </div>
            <strong style="color: var(--text);">4.8</strong>
            <span style="color: var(--text-soft); font-size: 0.8125rem;">(4条)</span>
          </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 24px;">
          <!-- 评价项 1 -->
          <div style="padding-bottom: 24px; border-bottom: 1px solid var(--line);">
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: #1864ff; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.875rem;">李</div>
                <div>
                  <div style="display: flex; align-items: center; gap: 8px;">
                    <strong style="font-size: 0.9375rem; color: var(--text);">李女士</strong>
                    <span style="color: #1864ff; font-size: 0.75rem; background: #eff6ff; padding: 2px 6px; border-radius: 4px;">白癜风 (面部)</span>
                  </div>
                </div>
              </div>
              <div style="text-align: right;">
                <div style="color: #f59e0b; display: flex; gap: 2px; justify-content: flex-end; margin-bottom: 4px;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                </div>
                <span style="color: var(--text-lighter); font-size: 0.75rem;">2026-04-10</span>
              </div>
            </div>
            <p style="color: var(--text); font-size: 0.9375rem; line-height: 1.6; margin: 0;">张主任非常耐心，详细解释了我的病情和治疗方案。经过6个月的NB-UVB光疗，脸部白斑复色率达到了80%，效果超出预期！强烈推荐！</p>
          </div>
          
          <!-- 评价项 2 -->
          <div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: #1864ff; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.875rem;">陈</div>
                <div>
                  <div style="display: flex; align-items: center; gap: 8px;">
                    <strong style="font-size: 0.9375rem; color: var(--text);">陈先生</strong>
                    <span style="color: #1864ff; font-size: 0.75rem; background: #eff6ff; padding: 2px 6px; border-radius: 4px;">节段型白癜风</span>
                  </div>
                </div>
              </div>
              <div style="text-align: right;">
                <div style="color: #f59e0b; display: flex; gap: 2px; justify-content: flex-end; margin-bottom: 4px;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                </div>
                <span style="color: var(--text-lighter); font-size: 0.75rem;">2026-03-25</span>
              </div>
            </div>
            <p style="color: var(--text); font-size: 0.9375rem; line-height: 1.6; margin: 0;">我的节段型白癜风已经有3年了，之前在其他医院治疗效果不好。来这里找张主任后，制定了针对性方案，4个月后明显改善，非常感谢！</p>
          </div>
        </div>

        <button style="width: 100%; margin-top: 24px; padding: 12px 0; background: var(--surface-soft); color: var(--text-soft); border: none; border-radius: 8px; font-size: 0.875rem; cursor: pointer; transition: all 0.2s ease;">
          查看全部4条评价 ∨
        </button>
      </div>
      
    </div>

    <!-- 右侧边栏 -->
