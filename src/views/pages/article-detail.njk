{% extends "layouts/base.njk" %}

{% block content %}
<section class="container content-section detail-layout">
  <div class="page-stack">
    <article class="card-surface article-detail-hero">
      <nav class="breadcrumbs compact-breadcrumbs">
        {% for item in breadcrumbs %}
        <a href="{{ item.href }}">{{ item.label }}</a>{% if not loop.last %}<span>›</span>{% endif %}
        {% endfor %}
      </nav>
      <span class="article-category">{{ article.category }}</span>
      <h1>{{ article.title }}</h1>
      <div class="article-meta">
        <span>{{ author.name }}</span>
        <span>{{ article.publishDate }}</span>
        <span>{{ article.views }} 阅读</span>
        <span>{{ article.readingTime }}</span>
      </div>
      <p class="detail-intro">{{ article.excerpt }}</p>
      <div class="tag-cloud compact">
        {% for tag in article.tags %}
        <span class="tag-chip">{{ tag }}</span>
        {% endfor %}
      </div>
    </article>

    <article class="card-surface">
      <h2>2026 年主流治疗方案对比</h2>
      <div class="table-wrap">
        <table class="comparison-table">
          <thead>
            <tr><th>方案</th><th>适用人群</th><th>疗程</th><th>特点</th></tr>
          </thead>
          <tbody>
            {% for row in detailTable %}
            <tr>
              {% for col in row %}<td>{{ col }}</td>{% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </article>

    {% for item in detailSections %}
    <article class="card-surface">
      <h2>{{ loop.index }}. 诊疗重点</h2>
      <p>{{ item }}</p>
    </article>
    {% endfor %}

    <article class="card-surface">
      <div class="section-title with-link inner-title">
        <div>
          <h2>患者常见问题</h2>
          <p>围绕诊疗、复发和长期管理的高频问题。</p>
        </div>
        <span>FAQPage Schema</span>
      </div>
      <div class="faq-list">
        {% for item in detailFaqs %}
        {% set faqItem = { question: item, answer: '建议结合病程、部位、分型和既往治疗史，由专病医生综合判断。' } %}
        {% include "components/faq-item.njk" %}
        {% endfor %}
      </div>
    </article>

    <article class="card-surface">
      <h2>参考文献</h2>
      <ul class="simple-list">
        {% for item in references %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </article>

    <article class="card-surface">
      <div class="section-title with-link inner-title">
        <div>
          <h2>患者评价</h2>
          <p>文章内容的读者反馈。</p>
        </div>
        <span>★ 4.8</span>
      </div>
      <div class="review-grid single-column">
        {% for review in articleReviews %}
        {% set reviewItem = review %}
        {% include "components/review-card.njk" %}
        {% endfor %}
      </div>
    </article>
  </div>

  <aside class="detail-sidebar">
    <article class="card-surface">
      <h2 style="font-size: 1rem; margin-bottom: 16px;">编审医生</h2>
      <div class="doctor-card-head" style="margin-bottom: 12px;">
        <span class="doctor-avatar" style="background: #1864ff; color: #fff;">{{ author.name | first }}</span>
        <div>
          <strong style="font-size: 1rem;">{{ author.name }}</strong>
          <p style="font-size: 0.8125rem; color: var(--text-soft); margin-top: 4px;">{{ author.department }} · {{ author.title }}</p>
        </div>
      </div>
      <p style="font-size: 0.8125rem; color: var(--text-soft); line-height: 1.5; margin-bottom: 16px;">
        从医{{ author.experience }}年，累计诊治{{ author.cases }}+例患者，擅长{{ author.specialties | join('、') }}的综合治疗。
      </p>
      <div style="display: flex; gap: 8px; margin-bottom: 16px; text-align: center;">
        <div style="flex: 1; background: #f8fafc; padding: 12px 0; border-radius: 8px;">
          <strong style="display: block; color: #1864ff; font-size: 1.125rem;">{{ author.experience }}年</strong>
          <span style="font-size: 0.75rem; color: var(--text-soft);">从业年限</span>
        </div>
        <div style="flex: 1; background: #f8fafc; padding: 12px 0; border-radius: 8px;">
          <strong style="display: block; color: #1864ff; font-size: 1.125rem;">{{ author.cases }}+</strong>
          <span style="font-size: 0.75rem; color: var(--text-soft);">诊治病例</span>
        </div>
      </div>
      <a class="button primary" href="/experts/{{ author.id or author.slug }}" style="width: 100%; border-radius: 8px; justify-content: center; background: #eff6ff; color: #1864ff;">查看医生详情</a>
    </article>

    <article class="card-surface" style="background: #1864ff; color: #fff;">
      <h2 style="font-size: 1rem; margin-bottom: 8px; color: #fff;">免费预约专家门诊</h2>
      <p style="font-size: 0.8125rem; opacity: 0.9; margin: 0 0 4px 0;">中国医科院附属第二、第四分院</p>
      <p style="font-size: 0.8125rem; opacity: 0.9; margin: 0 0 16px 0;">挂号费 ¥300 · 门诊时间 8:00-18:00</p>
      <div class="button-stack">
        <a class="button" href="{{ site.appointmentPath }}" style="width: 100%; justify-content: center; background: #fff; color: #1864ff; border-radius: 8px; border: none;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          立即预约
        </a>
        <a class="button" href="tel:{{ site.contactCards[0].value }}" style="width: 100%; justify-content: center; background: rgba(255,255,255,0.2); color: #fff; border-radius: 8px; border: none;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {{ site.contactCards[0].value | default('010-8888-8888') }}
        </a>
      </div>
    </article>

    <article class="card-surface sticky-card">
      <h2 style="font-size: 1rem; margin-bottom: 16px;">相关文章</h2>
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
        {% for relArticle in relatedArticles %}
        <li>
          <span style="font-size: 0.75rem; color: var(--text-lighter); display: block; margin-bottom: 4px;">{{ relArticle.category }}</span>
          <a href="/articles/{{ relArticle.slug }}" style="font-size: 0.875rem; color: var(--text); line-height: 1.4; text-decoration: none;">{{ relArticle.title }}</a>
        </li>
        {% endfor %}
      </ul>
    </article>
  </aside>
</section>
{% endblock %}
