          <p style="margin: 0 0 12px 0; font-size: 0.875rem; color: var(--text);">本周出诊安排</p>
          <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; text-align: center; font-size: 0.75rem;">
            <div style="color: var(--text-soft); margin-bottom: 8px;">一</div>
            <div style="color: var(--text-soft); margin-bottom: 8px;">二</div>
            <div style="color: var(--text-soft); margin-bottom: 8px;">三</div>
            <div style="color: var(--text-soft); margin-bottom: 8px;">四</div>
            <div style="color: var(--text-soft); margin-bottom: 8px;">五</div>
            <div style="color: var(--text-soft); margin-bottom: 8px;">六</div>
            <div style="color: var(--text-soft); margin-bottom: 8px;">日</div>
            
            <!-- 上午 -->
