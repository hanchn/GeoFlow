<header class="site-header">
  <div class="container header-bar">
    <a class="brand" href="/">
      <div class="brand-mark">医</div>
      <div class="brand-text">
        <strong>{{ site.name }}</strong>
        <small>专业化 · 权威 · 可追踪</small>
      </div>
    </a>

    <nav class="site-nav">
      {% for item in navItems %}
      <a class="nav-link {% if activeNav == item.key %}is-active{% endif %}" href="{{ item.href }}">{{ item.label }}</a>
      {% endfor %}
      <a class="nav-link {% if activeNav == 'contact' %}is-active{% endif %}" href="/contact">联系我们</a>
    </nav>

    <div class="header-actions">
      <button class="search-btn" type="button" data-search-open>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <span>搜索</span>
      </button>
      <a class="header-btn primary" href="{{ site.appointmentPath }}">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        预约挂号
      </a>
      <a class="header-btn secondary" href="tel:{{ site.phone }}">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        {{ site.phone }}
      </a>
    </div>
  </div>
</header>
