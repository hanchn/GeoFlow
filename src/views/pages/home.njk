{% extends "layouts/base.njk" %}

{% block content %}
<section class="home-hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <div class="eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        北京市皮肤科重点专科 · 成立23年
      </div>
      <h1 style="font-size: 3.5rem; line-height: 1.2; margin-bottom: 24px; color: #ffffff;">北京白癜风皮肤病专科医院</h1>
      <p class="subtitle" style="font-size: 1.125rem; margin-bottom: 48px;">专注白癜风·银屑病诊疗23年 · NB-UVB光疗权威机构</p>
      
      <div class="hero-stats">
        <div>
          <strong>12万+</strong>
          <span>累计诊治病例</span>
        </div>
        <div>
          <strong>42+</strong>
          <span>专业医生</span>
        </div>
        <div>
          <strong>23年</strong>
          <span>专科经验</span>
        </div>
        <div>
          <strong>4.9分</strong>
          <span>患者满意度</span>
        </div>
      </div>
      
      <div class="button-row">
        <a class="button" href="{{ site.appointmentPath }}" style="background: #ffffff; color: #1864ff; border-radius: 8px; min-width: 140px; height: 48px; padding: 0 32px; font-size: 1rem;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          立即预约
        </a>
        <a class="button" href="/departments/vitiligo" style="background: rgba(255,255,255,0.15); color: #ffffff; border-radius: 8px; min-width: 140px; height: 48px; padding: 0 32px; font-size: 1rem;">
          了解治疗方案
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left: 8px;"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </a>
      </div>
    </div>

    <div class="hero-form">
      <div class="hero-form-title">免费在线咨询</div>
      <div class="hero-form-desc">专业医生24小时在线，平均响应时间 &lt; 3分钟</div>
      
      <div class="hero-form-options">
        <div class="hero-form-option">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle></svg>
          您的症状持续多久了？
        </div>
        <div class="hero-form-option">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle></svg>
          是否有家族病史？
        </div>
        <div class="hero-form-option">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle></svg>
          之前是否接受过治疗？
        </div>
        <div class="hero-form-option">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle></svg>
          发病部位在哪里？
        </div>
      </div>
      
      <button class="hero-form-submit">提交咨询，免费获取方案</button>
      
      <div class="hero-form-promises">
        <span style="color: #10b981;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg> 隐私保护</span>
        <span style="color: #64748b;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> 7x12小时</span>
        <span style="color: #f59e0b;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> 免费咨询</span>
      </div>
    </div>
  </div>
</section>

<section class="container content-section">
  <div class="section-title with-link">
    <div>
      <h2>专家团队</h2>
      <p>围绕白癜风、银屑病、儿童皮肤等专病方向建立多学科团队。</p>
    </div>
    <a href="/experts">查看全部</a>
  </div>
  <div class="doctor-grid">
    {% for doctor in featuredDoctors %}
    {% set cardDoctor = doctor %}
    {% include "components/doctor-card.njk" %}
    {% endfor %}
  </div>
</section>

<section class="container content-section">
  <div class="section-title with-link">
    <div>
      <h2>科普文章</h2>
      <p>从病因、治疗到长期管理，帮助患者建立更清晰的诊疗认知。</p>
    </div>
    <a href="/articles">查看更多</a>
  </div>
  <div class="article-grid compact-grid">
    {% for article in featuredArticles %}
    {% set cardArticle = article %}
    {% include "components/article-card.njk" %}
    {% endfor %}
  </div>
</section>

<section class="container content-section">
  <div class="section-title">
    <h2>就医流程</h2>
    <p>从初诊评估到治疗随访，全流程节点清晰可追踪。</p>
  </div>
  <div class="process-grid">
    {% for item in processSteps %}
    <article class="process-card">
      <h3>{{ loop.index }}. {{ item.title }}</h3>
      <p>{{ item.text }}</p>
    </article>
    {% endfor %}
  </div>
</section>

<section class="container content-section" id="patient-stories">
  <div class="section-title with-link">
    <div>
      <h2>患者评价</h2>
      <p>来自门诊患者的真实反馈。</p>
    </div>
    <a href="/cases">查看更多案例</a>
  </div>
  <div class="review-grid">
    {% for review in patientStories %}
    {% set reviewItem = review %}
    {% include "components/review-card.njk" %}
    {% endfor %}
  </div>
</section>

<section class="container content-section">
  <div class="section-title">
    <h2>常见问题</h2>
    <p>围绕高频问题整理基础判断与就诊建议。</p>
  </div>
  <div class="faq-list">
    {% for item in homeFaqs %}
    {% set faqItem = item %}
    {% include "components/faq-item.njk" %}
    {% endfor %}
  </div>
</section>

<section class="container content-section">
  <div class="section-title">
    <h2>联系我们</h2>
    <p>电话、地址与门诊时间一目了然。</p>
  </div>
  <div class="contact-grid">
    {% for item in contactCards %}
    {% set contactItem = item %}
    {% include "components/contact-card.njk" %}
    {% endfor %}
  </div>
</section>
{% endblock %}
